{
  "$schema": "https://raw.githubusercontent.com/nicedozie4u/tauri-docs/dev/src/content/docs/_schema/config.schema.json",
  "productName": "Omni",
  "version": "0.1.0",
  "identifier": "com.omni.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Omni",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_UPDATER_PUBKEY",
      "endpoints": [
        "https://omniapp.org/api/v1/releases/check?current_version={{current_version}}&target={{target}}-{{arch}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
